# ─────────────────────────────────────────────────────────────────
# Micro-Earth 后端环境变量配置示例
# 复制本文件为 .env，填入对应值后重启后端即可生效
# ─────────────────────────────────────────────────────────────────

# ── LLM 后端选择 ──────────────────────────────────────────────────
# 可选值：stub（默认，无 LLM） | ollama（本地免费）| groq（云端免费）| openai（付费）
LLM_BACKEND=stub

# ── 方案 1：Ollama 本地（推荐，完全免费，无需联网）───────────────
# 1. 安装 Ollama: https://ollama.com/download
# 2. 拉取模型: ollama pull llama3.2:3b
# 3. 启动服务: ollama serve
# 4. 设置以下变量：
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# 低显存可选: qwen2.5:1.5b（约 1GB）、tinyllama（约 637MB）

# ── 方案 2：Groq 云端（免费额度 14,400 token/天）─────────────────
# 1. 注册免费账号: https://console.groq.com
# 2. 创建 API Key（免费，无需绑卡）
# 3. 设置以下变量：
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama3-8b-8192
# 可选模型: gemma2-9b-it | mixtral-8x7b-32768 | llama-3.1-8b-instant

# ── 方案 3：OpenAI（付费，按量计费）─────────────────────────────
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini
